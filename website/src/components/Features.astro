---
const features = [
  {
    icon: '◆',
    title: '2D Drawing',
    description: 'Immediate-mode vector drawing with shapes, text, images, gradients, and blend modes. GPU-instanced batching for high performance.',
  },
  {
    icon: '◇',
    title: '3D Rendering',
    description: 'PBR and Blinn-Phong materials, shadow mapping, mesh primitives, OBJ/USDZ loading, and orbit camera.',
  },
  {
    icon: '⚡',
    title: 'GPU Compute',
    description: 'Metal compute shaders with typed GPUBuffer<T>, image processing kernels, and GPU particle systems.',
  },
  {
    icon: '✦',
    title: 'Post-Processing',
    description: 'Bloom, blur, chromatic aberration, glitch, and custom shader effects via PostProcessPipeline.',
  },
  {
    icon: '♪',
    title: 'Audio',
    description: 'Real-time FFT analysis, beat detection, and sound file playback via AVAudioEngine.',
  },
  {
    icon: '⬡',
    title: 'Physics',
    description: '2D physics world with rigid bodies, constraints, collision detection, and spatial hashing.',
  },
  {
    icon: '◎',
    title: 'Machine Learning',
    description: 'CoreML integration, 22+ Vision request types, style transfer, and GPU texture conversion.',
  },
  {
    icon: '↗',
    title: 'Syphon Output',
    description: 'Real-time video sharing to VJ software, projection mapping tools, and recording applications.',
  },
];
---

<section id="features" class="relative px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl">
        Everything you need
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-text-muted">
        From 2D sketches to GPU compute pipelines — a comprehensive creative coding toolkit built on Metal.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((feature) => (
        <div class="group rounded-2xl border border-border bg-bg-card p-6 transition-all hover:border-accent/30 hover:bg-bg-card-hover">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-lg text-accent">
            {feature.icon}
          </div>
          <h3 class="mb-2 text-base font-semibold text-text">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
