---
const base = import.meta.env.BASE_URL;
---

<footer class="border-t border-border px-6 py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 sm:flex-row">
    <div class="text-sm text-text-muted">
      MIT License
    </div>
    <div class="flex items-center gap-6">
      <a
        href={`${base}/documentation/metaphor/`}
        class="text-sm text-text-muted transition-colors hover:text-text"
      >
        ドキュメント
      </a>
      <a
        href="https://github.com/shinyaoguri/metaphor"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-text-muted transition-colors hover:text-text"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
