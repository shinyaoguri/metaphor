---
import { getContent, docsUrl, githubUrl, homeFor, otherLang, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = getContent(lang);
const other = otherLang(lang);
---

<footer class="border-t border-border px-6 py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 sm:flex-row">
    <div class="flex items-center gap-3 text-sm text-text-muted">
      <span class="font-display text-base font-semibold text-text">metaphor</span>
      <span>·</span>
      <span>{t.footer.license}</span>
    </div>
    <div class="flex items-center gap-6 text-sm text-text-muted">
      <a href={docsUrl} class="transition-colors hover:text-text">{t.footer.docs}</a>
      <a href={homeFor(other)} class="transition-colors hover:text-text">{t.nav.toggleLabel}</a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-text"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
