---
import GenerativeCanvas from './GenerativeCanvas.astro';
import { getContent, docsUrl, githubUrl, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = getContent(lang);
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-16">
  <!-- Live generative background -->
  <GenerativeCanvas />
  <!-- Readability halo behind the centered content; the fluid stays vivid at the edges -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(62% 54% at 50% 46%, rgba(238,243,242,0.74), rgba(238,243,242,0.30) 52%, rgba(238,243,242,0) 78%);"
  ></div>
  <!-- Bottom fade so the hero blends into the page below -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-bg"></div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface/80 px-4 py-1.5 text-sm text-text-muted backdrop-blur">
      <span class="h-2 w-2 rounded-full bg-accent"></span>
      {t.hero.badge}
    </div>

    <h1 class="font-display mb-6 text-5xl font-semibold leading-tight tracking-tight sm:text-7xl">
      {t.hero.titleLead}<br />
      <span class="bg-gradient-to-r from-accent via-accent-light to-accent-2 bg-clip-text text-transparent">
        {t.hero.titleAccent}
      </span>
    </h1>

    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-text-muted sm:text-xl">
      {t.hero.lead}
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href={docsUrl}
        class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-accent-glow transition-all hover:bg-accent-light hover:shadow-xl"
      >
        {t.hero.ctaDocs}
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-surface/80 px-6 py-3 text-sm font-semibold text-text backdrop-blur transition-all hover:border-accent/50 hover:bg-surface"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        {t.hero.ctaGithub}
      </a>
    </div>

    <!-- Install snippets -->
    <div class="mx-auto mt-12 flex max-w-xl flex-col gap-2 text-left font-mono text-sm">
      <div class="flex items-center gap-3 rounded-xl border border-border bg-surface/80 px-5 py-3 backdrop-blur">
        <span class="shrink-0 rounded bg-accent-2/15 px-1.5 py-0.5 text-xs text-accent-2">{t.hero.brewLabel}</span>
        <code class="truncate text-text-muted">brew install shinyaoguri/tap/metaphor</code>
      </div>
      <div class="flex items-center gap-3 rounded-xl border border-border bg-surface/80 px-5 py-3 backdrop-blur">
        <span class="shrink-0 rounded bg-accent/15 px-1.5 py-0.5 text-xs text-accent">{t.hero.swiftLabel}</span>
        <code class="truncate text-text-muted">.package(url: "…/metaphor.git", from: "0.4.0")</code>
      </div>
    </div>

    <p class="mt-6 text-xs tracking-wide text-text-muted">{t.hero.envNote}</p>
  </div>
</section>
