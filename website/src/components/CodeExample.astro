---
import { getContent, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = getContent(lang);

// Light-theme syntax colors (earthy, matched to the site palette).
const kw = 'text-[#a25d8a]';   // keywords — muted magenta
const ty = 'text-[#2f8f83]';   // types — teal
const fn = 'text-[#3b6ea5]';   // functions — blue
const nu = 'text-[#b5651d]';   // numbers — clay
const codeHtml = `<span class="${kw}">import</span> metaphor

<span class="${kw}">@main</span>
<span class="${kw}">final class</span> <span class="${ty}">MySketch</span>: <span class="${ty}">Sketch</span> {
    <span class="${kw}">var</span> config: <span class="${ty}">SketchConfig</span> {
        <span class="${ty}">SketchConfig</span>(width: <span class="${nu}">1280</span>, height: <span class="${nu}">720</span>)
    }

    <span class="${kw}">func</span> <span class="${fn}">draw</span>() {
        background(<span class="${nu}">0.1</span>)

        fill(.<span class="${ty}">white</span>)
        circle(width / <span class="${nu}">2</span>, height / <span class="${nu}">2</span>, <span class="${nu}">200</span>)

        noFill()
        stroke(.<span class="${ty}">red</span>)
        strokeWeight(<span class="${nu}">2</span>)
        <span class="${kw}">for</span> i <span class="${kw}">in</span> <span class="${nu}">0</span>..&lt;<span class="${nu}">12</span> {
            <span class="${kw}">let</span> angle = Float(i) * <span class="${nu}">.pi</span> / <span class="${nu}">6</span>
            <span class="${kw}">let</span> r = <span class="${nu}">150</span> + sin(time + angle) * <span class="${nu}">30</span>
            ellipse(
                width / <span class="${nu}">2</span> + cos(angle) * r,
                height / <span class="${nu}">2</span> + sin(angle) * r,
                <span class="${nu}">40</span>, <span class="${nu}">40</span>
            )
        }
    }
}`;
---

<section class="relative px-6 py-32">
  <div class="mx-auto max-w-6xl">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display mb-4 text-3xl font-semibold tracking-tight sm:text-4xl">
          {t.code.title}<br />
          <span class="text-accent">{t.code.titleAccent}</span>
        </h2>
        <p class="mb-6 text-lg leading-relaxed text-text-muted">
          {t.code.lead}
        </p>
        <ul class="space-y-3 text-sm text-text-muted">
          {t.code.points.map((point) => (
            <li class="flex items-center gap-2">
              <span class="text-accent-2">&#10003;</span>
              {point}
            </li>
          ))}
        </ul>
      </div>

      <div class="overflow-hidden rounded-2xl border border-border bg-surface shadow-sm">
        <div class="flex items-center gap-2 border-b border-border px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-[#e8688f]"></div>
          <div class="h-3 w-3 rounded-full bg-[#d3a24a]"></div>
          <div class="h-3 w-3 rounded-full bg-[#7c8a6b]"></div>
          <span class="ml-2 font-mono text-xs text-text-muted">MySketch.swift</span>
        </div>
        <pre class="overflow-x-auto p-5 text-sm leading-relaxed text-text"><code class="font-mono" set:html={codeHtml} /></pre>
      </div>
    </div>
  </div>
</section>
