#!/bin/sh
#
# pre-push: ensure generated AI-facing files track their inputs
#
# llms.txt is regenerated and verified when the push touches:
#   - Sources/**/*.swift
#   - scripts/generate-llms-txt.py
#
# docs/ai/examples-index.{md,json} is regenerated and verified when the
# push touches:
#   - Examples/**
#   - scripts/generate-examples-index.py
#
# If a regenerated file differs from the checked-in version, the hook aborts
# the push so the contributor can `git add` and amend.
#
# Activated by `make setup` (or `make hooks`) via
# `git config core.hooksPath ./scripts/hooks`.

set -e

# Read pushed refs from stdin per githooks(5) and detect changes for both
# generated artifacts. Format: <local_ref> <local_sha> <remote_ref> <remote_sha>
# When pushing a brand-new branch, remote_sha is 40 zeros — fall back to the
# merge-base with origin/main.
needs_llms=0
needs_index=0
needs_shaders=0
zero=0000000000000000000000000000000000000000

while read -r _ local_sha _ remote_sha; do
    # Skip deletes (local_sha == zero)
    [ "$local_sha" = "$zero" ] && continue

    if [ "$remote_sha" = "$zero" ]; then
        # New branch: compare against origin/main if available
        base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"
        if [ -z "$base" ]; then
            # No baseline — assume all checks are needed
            needs_llms=1
            needs_index=1
            needs_shaders=1
            break
        fi
        range="${base}..${local_sha}"
    else
        range="${remote_sha}..${local_sha}"
    fi

    # llms.txt depends on Sources/ AND on its generator script.
    if git diff --name-only "$range" \
        -- 'Sources/**/*.swift' 'scripts/generate-llms-txt.py' \
        | grep -q .; then
        needs_llms=1
    fi
    # examples index depends on Examples/ AND on its generator script.
    if git diff --name-only "$range" \
        -- 'Examples/' 'scripts/generate-examples-index.py' \
        | grep -q .; then
        needs_index=1
    fi
    # shader sources (.txt) depend on Metal/*.metal AND on the generator script.
    if git diff --name-only "$range" \
        -- 'Sources/MetaphorCore/Shaders/' 'scripts/generate-shader-sources.py' \
        | grep -q .; then
        needs_shaders=1
    fi
done

# --- llms.txt staleness check -------------------------------------------------
if [ "$needs_llms" -eq 1 ]; then
    echo "[pre-push] Sources/ or generator changed — verifying llms.txt is up to date..."
    llms_log="$(mktemp)"
    if ! make llms-txt >"$llms_log" 2>&1; then
        echo "[pre-push] ❌ make llms-txt failed. Fix the build and re-push." >&2
        echo "[pre-push] --- make llms-txt output (tail) ---" >&2
        tail -40 "$llms_log" >&2
        rm -f "$llms_log"
        exit 1
    fi
    rm -f "$llms_log"
    if ! git diff --quiet llms.txt 2>/dev/null; then
        echo "[pre-push] ❌ llms.txt is stale. Regenerated for you — review and commit:" >&2
        echo "" >&2
        echo "    git add llms.txt && git commit --amend --no-edit  # or a new commit" >&2
        echo "    git push" >&2
        echo "" >&2
        exit 1
    fi
    echo "[pre-push] ✅ llms.txt is up to date."
fi

# --- examples index staleness check ------------------------------------------
if [ "$needs_index" -eq 1 ]; then
    echo "[pre-push] Examples/ or generator changed — verifying examples index is up to date..."
    if ! python3 scripts/generate-examples-index.py >/dev/null 2>&1; then
        echo "[pre-push] ❌ generate-examples-index.py failed." >&2
        exit 1
    fi
    if ! git diff --quiet docs/ai/examples-index.md docs/ai/examples-index.json 2>/dev/null; then
        echo "[pre-push] ❌ examples index is stale. Regenerated for you — review and commit:" >&2
        echo "" >&2
        echo "    git add docs/ai/examples-index.md docs/ai/examples-index.json" >&2
        echo "    git commit --amend --no-edit  # or a new commit" >&2
        echo "    git push" >&2
        echo "" >&2
        exit 1
    fi
    echo "[pre-push] ✅ examples index is up to date."
fi

# --- shader sources staleness check -------------------------------------------
if [ "$needs_shaders" -eq 1 ]; then
    echo "[pre-push] Shaders changed — verifying ShaderSources/*.txt are up to date..."
    if ! python3 scripts/generate-shader-sources.py --check; then
        echo "[pre-push] ❌ ShaderSources/*.txt are stale (canonical is Metal/*.metal)." >&2
        echo "[pre-push] Regenerate and commit:" >&2
        echo "" >&2
        echo "    python3 scripts/generate-shader-sources.py" >&2
        echo "    git add Sources/MetaphorCore/Shaders/ShaderSources" >&2
        echo "    git commit --amend --no-edit  # or a new commit" >&2
        echo "" >&2
        exit 1
    fi
    echo "[pre-push] ✅ shader sources are up to date."
fi

exit 0
