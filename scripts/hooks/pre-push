#!/bin/sh
#
# pre-push: ensure llms.txt tracks Sources/**/*.swift changes
#
# When the commits being pushed touch any Swift source under Sources/, this
# hook regenerates llms.txt and aborts the push if the result differs from
# what is checked in. The contributor can then `git add llms.txt`, amend or
# add a follow-up commit, and re-push.
#
# Activated by `make setup` via `git config core.hooksPath ./scripts/hooks`.

set -e

# Read pushed refs from stdin per githooks(5) and detect Swift changes.
# Format: <local_ref> <local_sha> <remote_ref> <remote_sha>
# When pushing a brand-new branch, remote_sha is 40 zeros — fall back to
# `@{upstream}` if it exists, else compare against the merge-base with origin/main.
needs_check=0
zero=0000000000000000000000000000000000000000

while read -r _ local_sha _ remote_sha; do
    # Skip deletes (local_sha == zero)
    [ "$local_sha" = "$zero" ] && continue

    if [ "$remote_sha" = "$zero" ]; then
        # New branch: compare against origin/main if available
        base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"
        if [ -z "$base" ]; then
            # No baseline — assume the branch needs a check
            needs_check=1
            break
        fi
        range="${base}..${local_sha}"
    else
        range="${remote_sha}..${local_sha}"
    fi

    if git diff --name-only "$range" -- 'Sources/**/*.swift' | grep -q .; then
        needs_check=1
        break
    fi
done

if [ "$needs_check" -eq 0 ]; then
    exit 0
fi

# Regenerate llms.txt and compare.
echo "[pre-push] Sources/**/*.swift changed — verifying llms.txt is up to date..."
if ! make llms-txt >/dev/null 2>&1; then
    echo "[pre-push] ❌ make llms-txt failed. Fix the build and re-push." >&2
    exit 1
fi

if ! git diff --quiet llms.txt 2>/dev/null; then
    echo "[pre-push] ❌ llms.txt is stale. Regenerated for you — review and commit:" >&2
    echo "" >&2
    echo "    git add llms.txt && git commit --amend --no-edit  # or a new commit" >&2
    echo "    git push" >&2
    echo "" >&2
    exit 1
fi

echo "[pre-push] ✅ llms.txt is up to date."
exit 0
